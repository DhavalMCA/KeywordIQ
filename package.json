{
  "name": "keywordiq",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && .venv/Scripts/python.exe -m uvicorn main:app --reload --port 8000",
    "install:all": "npm install && cd frontend && npm install",
    "setup": "npm run install:all && cd backend && pip install -r requirements.txt",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
