{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicy": {
      "type": "ON_FAILURE",
      "retries": 3
    },
    "healthcheck": {
      "path": "/health",
      "port": 8000
    }
  }
}
